{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "GenAI Agent Platform 运维监控面板 — 纯云端 API 架构，无 GPU 面板",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "description": "HTTP 请求速率，按 1 分钟窗口计算",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(agent_http_requests_total[1m]))",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "sum by (endpoint) (rate(agent_http_requests_total[1m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Request Latency P95 (s)",
      "description": "HTTP 请求 P95 延迟，按 5 分钟窗口计算",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P95 Overall",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(agent_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{endpoint}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "LLM Call Rate",
      "description": "LLM API 调用速率，按 1 分钟窗口计算",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(agent_llm_calls_total[1m]))",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "sum by (provider, model) (rate(agent_llm_calls_total[1m]))",
          "legendFormat": "{{provider}} / {{model}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "LLM Latency P95 (s)",
      "description": "LLM API 调用 P95 延迟，按 5 分钟窗口计算",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_llm_call_duration_seconds_bucket[5m])))",
          "legendFormat": "P95 Overall",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider, model) (rate(agent_llm_call_duration_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} / {{model}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Tool Call Success Rate",
      "description": "工具调用成功率，success / total，按 5 分钟窗口计算",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(agent_tool_calls_total{status=\"success\"}[5m])) / sum(rate(agent_tool_calls_total[5m]))",
          "legendFormat": "Overall Success Rate",
          "refId": "A"
        },
        {
          "expr": "sum by (tool_name) (rate(agent_tool_calls_total{status=\"success\"}[5m])) / sum by (tool_name) (rate(agent_tool_calls_total[5m]))",
          "legendFormat": "{{tool_name}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "RAG Retrieval Latency (s)",
      "description": "RAG 检索 P95 延迟，按 5 分钟窗口计算",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_rag_retrieval_duration_seconds_bucket[5m])))",
          "legendFormat": "P95 Overall",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, engine) (rate(agent_rag_retrieval_duration_seconds_bucket[5m])))",
          "legendFormat": "{{engine}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Active Sessions",
      "description": "当前活跃会话数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "agent_active_sessions",
          "legendFormat": "Active Sessions",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Token Usage (1h)",
      "description": "过去 1 小时的 LLM Token 使用量",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100000 },
              { "color": "red", "value": 500000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(agent_llm_tokens_total[1h]))",
          "legendFormat": "Total Tokens",
          "refId": "A"
        },
        {
          "expr": "sum by (type) (increase(agent_llm_tokens_total[1h]))",
          "legendFormat": "{{type}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Error Rate (4xx+5xx)",
      "description": "4xx 和 5xx 错误请求速率，按 5 分钟窗口计算",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 30,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(agent_http_requests_total{status_code=~\"4..|5..\"}[5m]))",
          "legendFormat": "Total Error Rate",
          "refId": "A"
        },
        {
          "expr": "sum by (status_code) (rate(agent_http_requests_total{status_code=~\"4..|5..\"}[5m]))",
          "legendFormat": "{{status_code}}",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
